{
    "name": "mailclient",
    "main": "src/app.js",
    "compatibility_date": "2026-05-11",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "./web/dist/",
        "binding": "assets"
    },
    "build": {
        "command": "npm install && cd web && npm install && npm run build"
    },
    "kv_namespaces": [
        {
            "binding": "data",
            "id": "aef3eafc393a44c396c292b53b0294e8"
        }
    ]
}
